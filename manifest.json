{
  "manifest_version": 3,
  "name": "AO3 Enhancer",
  "version": "1.1",
  "description": "Enhances AO3 by improving history functionality",
  "homepage_url": "https://github.com/williamwith4ms/ao3_enhancer",
  "author": "willliammmm",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ao3@willliammmm.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.archiveofourown.org/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "/popup/popup.html",
    "default_title": "AO3 Enhancer"
  },
  "options_ui": {
    "page": "/options/options.html",
    "open_in_tab": true
  }
}
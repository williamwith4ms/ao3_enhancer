{
  "manifest_version": 3,
  "name": "AO3 Additions",
  "version": "1.2.1",
  "description": "Provides various additional features for ao3",
  "homepage_url": "https://github.com/williamwith4ms/ao3_additions",
  "author": "willliammmm",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "icons": {
    "16": "/icons/icon-16.png",
    "32": "/icons/icon-32.png",
    "48": "/icons/icon-48.png",
    "64": "/icons/icon-64.png",
    "96": "/icons/icon-96.png",
    "128": "/icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ao3@willliammmm.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.archiveofourown.org/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "/icons/icon-16.png",
      "32": "/icons/icon-32.png"
    },
    "default_popup": "/popup/popup.html",
    "default_title": "AO3 Additions"
  },
  "options_ui": {
    "page": "/options/options.html",
    "open_in_tab": true
  }
}